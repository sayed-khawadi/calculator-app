<Window x:Class="CalculatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculator App"
        Height="600"
        Width="400"
        MinHeight="500"
        MinWidth="350"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="140"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Display -->
        <Border Grid.Row="0"
                Background="#2D2D30"
                CornerRadius="15"
                Padding="20"
                Margin="0,0,0,20">

            <TextBlock x:Name="DisplayText"
                       Text="0"
                       Foreground="White"
                       FontSize="48"
                       FontWeight="Bold"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"/>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Content="C" FontSize="24" Margin="5" Click="ClearButton_Click"/>
            <Button Grid.Row="0" Grid.Column="1" Content="⌫" FontSize="24" Margin="5" Click="BackspaceButton_Click"/>
            <Button Grid.Row="0" Grid.Column="2" Content="%" FontSize="24" Margin="5"/>
            <Button Grid.Row="0" Grid.Column="3" Content="÷" FontSize="24" Margin="5"/>

            <Button Grid.Row="1" Grid.Column="0" Content="7" FontSize="24" Margin="5" Click="NumberButton_Click"/>
            <Button Grid.Row="1" Grid.Column="1" Content="8" FontSize="24" Margin="5" Click="NumberButton_Click"/>
            <Button Grid.Row="1" Grid.Column="2" Content="9" FontSize="24" Margin="5" Click="NumberButton_Click"/>
            <Button Grid.Row="1" Grid.Column="3" Content="×" FontSize="24" Margin="5"/>

            <Button Grid.Row="2" Grid.Column="0" Content="4" FontSize="24" Margin="5" Click="NumberButton_Click"/>
            <Button Grid.Row="2" Grid.Column="1" Content="5" FontSize="24" Margin="5" Click="NumberButton_Click"/>
            <Button Grid.Row="2" Grid.Column="2" Content="6" FontSize="24" Margin="5" Click="NumberButton_Click"/>
            <Button Grid.Row="2" Grid.Column="3" Content="-" FontSize="24" Margin="5"/>

            <Button Grid.Row="3" Grid.Column="0" Content="1" FontSize="24" Margin="5" Click="NumberButton_Click"/>
            <Button Grid.Row="3" Grid.Column="1" Content="2" FontSize="24" Margin="5" Click="NumberButton_Click"/>
            <Button Grid.Row="3" Grid.Column="2" Content="3" FontSize="24" Margin="5" Click="NumberButton_Click"/>
            <Button Grid.Row="3" Grid.Column="3" Content="+" FontSize="24" Margin="5"/>

            <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="0" FontSize="24" Margin="5" Click="NumberButton_Click"/>
            <Button Grid.Row="4" Grid.Column="2" Content="." FontSize="24" Margin="5" Click="NumberButton_Click"/>
            <Button Grid.Row="4" Grid.Column="3" Content="=" FontSize="24" Margin="5"/>
        </Grid>
    </Grid>
</Window>