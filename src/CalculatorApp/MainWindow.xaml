<Window x:Class="CalculatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculator App"
        Height="690"
        Width="820"
        MinHeight="650"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>

        <!-- Theme brushes -->
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#111214"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#1B1D22"/>
        <SolidColorBrush x:Key="DisplayBackgroundBrush" Color="#22242A"/>
        <SolidColorBrush x:Key="NormalButtonBackgroundBrush" Color="#2D2F34"/>
        <SolidColorBrush x:Key="OperatorButtonBackgroundBrush" Color="#3B3F48"/>
        <SolidColorBrush x:Key="ClearButtonBackgroundBrush" Color="#4A2D2D"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A9ADB8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#F5C542"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FF7777"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#3A3D44"/>

        <Style x:Key="CalculatorButton" TargetType="Button">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource NormalButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OperatorButton" TargetType="Button" BasedOn="{StaticResource CalculatorButton}">
            <Setter Property="Background" Value="{DynamicResource OperatorButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <Style x:Key="EqualsButton" TargetType="Button" BasedOn="{StaticResource CalculatorButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#111214"/>
            <Setter Property="FontSize" Value="30"/>
        </Style>

        <Style x:Key="ClearButton" TargetType="Button" BasedOn="{StaticResource CalculatorButton}">
            <Setter Property="Background" Value="{DynamicResource ClearButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
        </Style>

        <Style x:Key="SmallActionButton" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111214"/>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="130"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="480"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Calculator area -->
        <Grid Grid.Column="0" Margin="0,0,18,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="175"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Display -->
            <Border Grid.Row="0"
                    Background="{DynamicResource DisplayBackgroundBrush}"
                    CornerRadius="22"
                    Padding="22"
                    Margin="0,0,0,22">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ExpressionText"
                               Grid.Row="0"
                               Text=""
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="21"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock x:Name="DisplayText"
                               Grid.Row="1"
                               Text="0"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="46"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

            <!-- Buttons -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0" Content="C" Style="{StaticResource ClearButton}" Click="ClearButton_Click"/>
                <Button Grid.Row="0" Grid.Column="1" Content="←" Style="{StaticResource OperatorButton}" Click="BackspaceButton_Click"/>
                <Button Grid.Row="0" Grid.Column="2" Content="(" Style="{StaticResource OperatorButton}" Click="ParenthesisButton_Click"/>
                <Button Grid.Row="0" Grid.Column="3" Content=")" Style="{StaticResource OperatorButton}" Click="ParenthesisButton_Click"/>
                <Button Grid.Row="0" Grid.Column="4" Content="%" Style="{StaticResource OperatorButton}" Click="PercentButton_Click"/>

                <Button Grid.Row="1" Grid.Column="0" Content="7" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click"/>
                <Button Grid.Row="1" Grid.Column="1" Content="8" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click"/>
                <Button Grid.Row="1" Grid.Column="2" Content="9" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click"/>
                <Button Grid.Row="1" Grid.Column="3" Content="÷" Style="{StaticResource OperatorButton}" Click="OperatorButton_Click"/>
                <Button Grid.Row="1" Grid.Column="4" Content="×" Style="{StaticResource OperatorButton}" Click="OperatorButton_Click"/>

                <Button Grid.Row="2" Grid.Column="0" Content="4" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click"/>
                <Button Grid.Row="2" Grid.Column="1" Content="5" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click"/>
                <Button Grid.Row="2" Grid.Column="2" Content="6" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click"/>
                <Button Grid.Row="2" Grid.Column="3" Content="-" Style="{StaticResource OperatorButton}" Click="OperatorButton_Click"/>
                <Button Grid.Row="2" Grid.Column="4" Content="+" Style="{StaticResource OperatorButton}" Click="OperatorButton_Click"/>

                <Button Grid.Row="3" Grid.Column="0" Content="1" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click"/>
                <Button Grid.Row="3" Grid.Column="1" Content="2" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click"/>
                <Button Grid.Row="3" Grid.Column="2" Content="3" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click"/>

                <Button Grid.Row="3" Grid.Column="3"
                        Grid.RowSpan="2"
                        Grid.ColumnSpan="2"
                        Content="="
                        Style="{StaticResource EqualsButton}"
                        Click="EqualsButton_Click"/>

                <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="0" Style="{StaticResource CalculatorButton}" Click="NumberButton_Click"/>
                <Button Grid.Row="4" Grid.Column="2" Content="." Style="{StaticResource CalculatorButton}" Click="NumberButton_Click"/>
            </Grid>
        </Grid>

        <!-- History area -->
        <Border Grid.Column="1"
                Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="22"
                Padding="18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="History"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="26"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>

                    <Button x:Name="ThemeToggleButton"
                            Grid.Column="1"
                            Content="Light Mode"
                            Width="130"
                            Style="{StaticResource SmallActionButton}"
                            Click="ToggleThemeButton_Click"/>
                </Grid>

                <ListBox x:Name="HistoryList"
                         Grid.Row="1"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource SecondaryTextBrush}"
                         FontSize="16"
                         Margin="0,0,0,16">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="2"
                        Content="Clear History"
                        Style="{StaticResource SmallActionButton}"
                        Click="ClearHistoryButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>